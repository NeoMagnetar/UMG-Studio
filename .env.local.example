# UMG Studio local Hermes Generate bridge example.
# Copy values into an untracked local env file for development.

# Browser-safe: points UMG Studio Generate to the local bridge.
# Preferred for real provider secrets because credentials stay server-side.
VITE_HERMES_GENERATE_URL=http://127.0.0.1:8787/api/hermes/generate

# Legacy direct browser endpoint compatibility.
# Used only when VITE_HERMES_GENERATE_URL is absent.
VITE_HERMES_ENDPOINT=http://localhost:3000/api/hermes

# Legacy browser-visible settings; local/dev only.
# Do not put real provider secrets in VITE_* variables for shared builds.
# Prefer bridge-side HERMES_API_KEY for real secrets.
VITE_HERMES_MODEL=hermes-default
VITE_HERMES_API_KEY=replace_me_only_for_local_legacy_dev

# Server-only: used by dev/hermes-generate-bridge.mjs.
# Do not put real secrets in VITE_* variables.
HERMES_PROVIDER_URL=https://provider.example/v1/chat/completions
HERMES_MODEL=example-model
HERMES_API_KEY=replace_me_in_untracked_local_env

# Optional bridge bind overrides.
HERMES_BRIDGE_HOST=127.0.0.1
HERMES_BRIDGE_PORT=8787
